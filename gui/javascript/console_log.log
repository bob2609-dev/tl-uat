// Update the populateIntegrationModalDropdown function directly
console.log('=== DIRECT FUNCTION UPDATE ===');

// Get the nested iframe where execution is happening
var mainIframe = document.querySelector('iframe[name="mainframe"]');
if (mainIframe) {
  var mainDoc = mainIframe.contentDocument || mainIframe.contentWindow.document;
  var workframe = mainDoc.querySelector('iframe[name="workframe"]');
  
  if (workframe) {
    var workframeDoc = workframe.contentDocument || workframe.contentWindow.document;
    console.log('Workframe accessed successfully');
    
    // Extract project ID from workframe URL
    var workframeUrl = workframe.src;
    var urlMatch = workframeUrl.match(/id=(\d+)/);
    var projectId = urlMatch ? urlMatch[1] : null;
    
    console.log('Project ID to use:', projectId);
    
    if (projectId) {
      // Create a new populateIntegrationModalDropdown function that uses the URL
      var newPopulateFunction = function() {
        console.log('=== MODAL POPULATE WITH URL PROJECT ID ===');
        console.log('Using project ID from URL:', projectId);
        
        // Get dropdown
        var dropdown = this.document.getElementById('integrationModalDropdown');
        if (!dropdown) {
          console.log('Modal dropdown not found');
          return;
        }
        
        // Clear existing options
        dropdown.empty();
        dropdown.append('<option value="">-- Select Integration --</option>');
        
        console.log('Using tproject_id:', projectId);
        
        // Fetch integrations using the extracted project ID
        fetch(window.location.origin + '/lib/execute/custom_bugtrack_integrator.php?action=list_integrations_for_project&tproject_id=' + projectId)
          .then(response => response.json())
          .then(data => {
            console.log('Integrations fetched:', data);
            console.log('Number of integrations:', data.integrations ? data.integrations.length : 0);
            
            if (data.success && data.integrations) {
              data.integrations.forEach(function(integration) {
                console.log('Adding integration:', integration.id, integration.name);
                dropdown.append('<option value="' + integration.id + '">' + integration.name + '</option>');
              });
              
              if (data.integrations.length === 1) {
                dropdown.val(data.integrations[0].id);
                console.log('Auto-selecting single integration:', data.integrations[0].id);
              }
            } else {
              console.log('No integrations found or error:', data);
            }
          })
          .catch(error => {
            console.error('Error fetching integrations:', error);
          });
        
        console.log('=== END MODAL POPULATE ===');
      };
      
      // Replace the function in the workframe
      workframeDoc.populateIntegrationModalDropdown = newPopulateFunction;
      console.log('Function replaced successfully');
      
      // Test the modal with the new function
      var execButtons = workframeDoc.querySelectorAll('[id^="save_results"]');
      var checkbox = workframeDoc.getElementById('createIssue');
      
      if (execButtons.length > 0 && checkbox) {
        console.log('Testing modal with new function...');
        checkbox.checked = true;
        checkbox.dispatchEvent(new Event('change'));
        execButtons[0].click();
        console.log('Modal should now show integrations for project:', projectId);
      }
    }
  }
}

