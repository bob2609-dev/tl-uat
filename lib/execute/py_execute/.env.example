# TestLink Optimized Execution Module - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=testlink
DB_PASSWORD=your_database_password_here
DB_NAME=testlink
DB_CHARSET=utf8mb4

# ===========================================
# CONNECTION POOL SETTINGS
# ===========================================
DB_POOL_SIZE=10
DB_POOL_RESET_SESSION=true
DB_CONNECTION_TIMEOUT=30
DB_READ_TIMEOUT=60

# ===========================================
# FASTAPI SERVER CONFIGURATION
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=true
LOG_LEVEL=info

# ===========================================
# CORS CONFIGURATION
# ===========================================
# For production, specify exact origins: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ===========================================
# TESTLINK INTEGRATION
# ===========================================
TESTLINK_SESSION_TIMEOUT=3600
DEFAULT_TESTPROJECT_ID=1
DEFAULT_TESTPLAN_ID=1
DEFAULT_BUILD_ID=1
DEFAULT_PLATFORM_ID=1

# ===========================================
# PERFORMANCE SETTINGS
# ===========================================
ENABLE_QUERY_CACHE=true
QUERY_CACHE_TTL=300
MAX_CONNECTION_RETRIES=3
CONNECTION_RETRY_DELAY=1

# ===========================================
# SECURITY SETTINGS
# ===========================================
# IMPORTANT: Change this in production!
SECRET_KEY=your-secret-key-here-change-in-production-urgently
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_FILE=logs/py_execute.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===========================================
# API RATE LIMITING
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true
ENABLE_API_DOCS=true
ENABLE_PERFORMANCE_MONITORING=true
