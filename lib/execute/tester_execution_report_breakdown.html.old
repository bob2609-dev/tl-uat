        function renderPassRateTrendChart(data) {
            var ctx = document.getElementById('pass_rate_trend_chart').getContext('2d');
            
            // Aggregate pass rates by date
            var dateGroups = {};
            data.forEach(function(row) {
                var date = row.execution_date_formatted;
                if (!dateGroups[date]) {
                    dateGroups[date] = {
                        totalPass: 0,
                        totalFail: 0,
                        passRates: []
                    };
                }
                dateGroups[date].totalPass += parseInt(row.passed_testcases) || 0;
                dateGroups[date].totalFail += parseInt(row.failed_testcases) || 0;
                if (row.pass_rate_percent) {
                    dateGroups[date].passRates.push(parseFloat(row.pass_rate_percent));
                }
            });
            
            var sortedDates = Object.keys(dateGroups).sort();
            var passRateData = sortedDates.map(date => {
                var group = dateGroups[date];
                var totalExecuted = group.totalPass + group.totalFail;
                return totalExecuted > 0 ? ((group.totalPass / totalExecuted) * 100).toFixed(1) : 0;
            });
            
            // Destroy existing chart
            if (window.passRateTrendChart) {
                window.passRateTrendChart.destroy();
            }
            
            window.passRateTrendChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: sortedDates,
                    datasets: [{
                        label: 'Pass Rate %',
                        data: passRateData,
                        borderColor: '#1D55A8',
                        backgroundColor: 'rgba(29, 85, 168, 0.1)',
                        borderWidth: 3,
                        tension: 0,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                font: {
                                    size: 12,
                                    weight: '600'
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Pass Rate: ' + context.parsed.y + '%';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100,
                            ticks: {
