        // Function to fetch assigned test cases per date separately
        function fetchAssignedDataByDate(projectId, startDate, endDate) {
            return $.ajax({
                url: 'ajax_assigned_data.php',
                type: 'POST',
                data: {
                    project_id: projectId,
                    start_date: startDate,
                    end_date: endDate
                },
                dataType: 'json'
            });
        }
        
        function renderCumulativeProgressChart(data, assignedDataByDate) {
            var ctx = document.getElementById('cumulative_progress_chart').getContext('2d');
            
            var dateGroups = {};
            data.forEach(function(row) {
                var date = row.execution_date_formatted;
                if (!dateGroups[date]) {
                    dateGroups[date] = {
                        executed: 0,
                        passed: 0
                    };
                }
                dateGroups[date].executed += parseInt(row.executed_testcases) || 0;
                dateGroups[date].passed += parseInt(row.passed_testcases) || 0;
            });
            
            var sortedDates = Object.keys(dateGroups).sort();
            var cumulativeExecuted = [];
            var cumulativePassed = [];
            var assignedData = []; // Will use separate assigned data
            var passRateData = [];
            var deltaData = [];
            var currentDateData = [];
            var totalExecuted = 0;
            var totalPassed = 0;
            
            // Get current date for highlighting
            var today = new Date().toISOString().split('T')[0];
            
            sortedDates.forEach(date => {
                totalExecuted += dateGroups[date].executed;
                totalPassed += dateGroups[date].passed;
                
                // Use daily incremental values (each day added on top of previous)
                cumulativeExecuted.push(totalExecuted);
                cumulativePassed.push(totalPassed);
                // No assigned data for now (line was disabled)
                assignedData.push(0);
                // Calculate pass rate percentage
                var passRate = totalExecuted > 0 ? ((totalPassed / totalExecuted) * 100).toFixed(1) : 0;
                passRateData.push(parseFloat(passRate));
                // Calculate delta (difference between executed and passed)
                deltaData.push(totalExecuted - totalPassed);
                // Check if this is current date
                currentDateData.push(date === today);
            });
            
            // Destroy existing chart
            if (window.cumulativeProgressChart) {
                window.cumulativeProgressChart.destroy();
            }
            
            // Store data globally for tooltip access
            window.currentCumulativeExecuted = cumulativeExecuted;
            window.currentCumulativePassed = cumulativePassed;
            window.currentAssignedData = assignedData; // Use assignedData (no accumulation)
            window.currentDateData = currentDateData;
            
            // Register delta lines plugin with different approach
            Chart.register({
                id: 'deltaLines',
                afterDraw: function(chart) {
                    var ctx = chart.ctx;
                    var xAxis = chart.scales.x;
                    var yAxis = chart.scales.y;
                    
                    // Only draw for cumulative progress chart
                    if (chart.canvas.id === 'cumulative_progress_chart') {
                        chart.data.datasets.forEach(function(dataset, datasetIndex) {
                            if (datasetIndex === 0) { // Executed dataset
                                var meta = chart.getDatasetMeta(datasetIndex);
                                meta.data.forEach(function(point, index) {
                                    if (index < chart.data.datasets[1].data.length) {
                                        var passedMeta = chart.getDatasetMeta(1);
                                        var passedPoint = passedMeta.data[index];
                                        
                                        if (point && passedPoint) {
                                            ctx.save();
                                            ctx.beginPath();
                                            ctx.moveTo(point.x, point.y);
                                            ctx.lineTo(passedPoint.x, passedPoint.y);
                                            ctx.strokeStyle = window.currentDateData[index] ? '#FF0000' : '#CCCCCC';
                                            ctx.lineWidth = window.currentDateData[index] ? 3 : 2;
                                            ctx.setLineDash([5, 5]);
                                            ctx.stroke();
                                            ctx.restore();
                                        }
                                    }
                                });
                            }
                        });
                    }
                }
            });
            
            window.cumulativeProgressChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: sortedDates,
                    datasets: [{
                        label: 'Cumulative Executed',
                        data: cumulativeExecuted,
                        borderColor: '#F25B16',
                        backgroundColor: 'rgba(242, 91, 22, 0.1)',
                        borderWidth: 3,
                        tension: 0,
                        fill: true,
                        pointBackgroundColor: function(context) {
                            return currentDateData[context.dataIndex] ? '#FF0000' : '#F25B16';
                        },
                        pointBorderColor: function(context) {
                            return currentDateData[context.dataIndex] ? '#FF0000' : '#F25B16';
                        },
                        pointRadius: function(context) {
                            return currentDateData[context.dataIndex] ? 6 : 4;
                        },
                        pointHoverRadius: function(context) {
                            return currentDateData[context.dataIndex] ? 8 : 6;
                        }
                    }, {
                        label: 'Cumulative Passed',
                        data: cumulativePassed,
                        borderColor: '#1D55A8',
                        backgroundColor: 'rgba(29, 85, 168, 0.1)',
                        borderWidth: 3,
                        tension: 0,
                        fill: true,
                        pointBackgroundColor: function(context) {
                            return currentDateData[context.dataIndex] ? '#FF0000' : '#1D55A8';
                        },
                        pointBorderColor: function(context) {
                            return currentDateData[context.dataIndex] ? '#FF0000' : '#1D55A8';
                        },
                        pointRadius: function(context) {
                            return currentDateData[context.dataIndex] ? 6 : 4;
                        },
                        pointHoverRadius: function(context) {
                            return currentDateData[context.dataIndex] ? 8 : 6;
                        }
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                font: {
                                    size: 12,
                                    weight: '600'
                                }
                            }
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                weight: 'bold'
                            },
                            bodyFont: {
                                size: 12
                            },
                            callbacks: {
                                title: function(context) {
                                    return 'Date: ' + context[0].label;
                                },
                                label: function(context) {
                                    var label = context.dataset.label || '';
                                    var value = context.parsed.y;
                                    var deltaIndex = context.dataIndex;
                                    
                                    // Get both values for calculation
                                    var executed = window.currentCumulativeExecuted[deltaIndex];
                                    var passed = window.currentCumulativePassed[deltaIndex];
                                    
                                    // Calculate delta percentage correctly
                                    var deltaValue = executed - passed;
                                    var deltaPercentage = ((deltaValue) / executed * 100).toFixed(1);
                                    
                                    return [
                                        'Executed: ' + executed,
                                        'Passed: ' + passed,
                                        'Delta: ' + deltaValue,
                                        'Delta %: ' + deltaPercentage + '%'
                                    ];
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            },
                            ticks: {
                                font: {
                                    size: 11
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });
        }
        
        function destroyCharts() {
            if (window.executedPassedTrendChart) {
                window.executedPassedTrendChart.destroy();
                window.executedPassedTrendChart = null;
            }
            if (window.executionTrendChart) {
                window.executionTrendChart.destroy();
                window.executionTrendChart = null;
            }
            if (window.passRateTrendChart) {
                window.passRateTrendChart.destroy();
                window.passRateTrendChart = null;
            }
            if (window.statusDistributionChart) {
                window.statusDistributionChart.destroy();
                window.statusDistributionChart = null;
            }
            if (window.cumulativeProgressChart) {
                window.cumulativeProgressChart.destroy();
                window.cumulativeProgressChart = null;
            }
        }
        
        function showChartError(message) {
            var errorHtml = '<div class="chart-error">' + message + '</div>';
            $('.chart-container').prepend(errorHtml);
        }
    </script>
</body>
</html>

